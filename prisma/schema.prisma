generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  passwordHash      String
  name              String
  photoUrl          String?
  language          String             @default("en")
  role              String             @default("USER") // "USER" or "ADMIN"
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  trips             Trip[]
  savedDestinations SavedDestination[]
  manifestGoals     ManifestGoal[]
}

model Trip {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  slug           String?       @unique
  startDate      DateTime
  endDate        DateTime
  description    String?
  coverPhotoUrl  String?
  type           String        @default("National") // "National" or "International"
  companionType  String        @default("Solo") // Solo, Couple, Friends, Family, Colleague
  currency       String        @default("INR")
  budgetEstimate Float?
  currentSavings Float         @default(0)
  travelPace     String        @default("Moderate") // Relaxed, Moderate, Packed
  mood           String?       // Adventure, Food, Luxury, Nature, Culture
  transportType  String?       // Flight, Train, Bus, Road Trip
  visibility     String        @default("Private") // Private, Public, Shared
  invitees       String?       // Comma-separated emails
  isPublic       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  stops          Stop[]
  expenses       Expense[]
  packingItems   PackingItem[]
  notes          Note[]
  contributions  Contribution[]
}

model Contribution {
  id        String   @id @default(uuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  amount    Float
  message   String?
  createdAt DateTime @default(now())
}

model Stop {
  id         String     @id @default(uuid())
  tripId     String
  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  cityName   String
  country    String
  startDate  DateTime?
  endDate    DateTime?
  orderIndex Int
  activities Activity[]
  notes      Note[]
}

model Activity {
  id          String   @id @default(uuid())
  stopId      String
  stop        Stop     @relation(fields: [stopId], references: [id], onDelete: Cascade)
  name        String
  description String?
  cost        Float    @default(0)
  duration    Int?     // duration in minutes
  type        String?  // e.g., 'Sightseeing', 'Food', 'Adventure'
  startTime   DateTime?
}

model Expense {
  id       String @id @default(uuid())
  tripId   String
  trip     Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category String // 'Transport', 'Stay', 'Activities', 'Meals'
  amount   Float
  currency String @default("INR")
}

model PackingItem {
  id       String  @id @default(uuid())
  tripId   String
  trip     Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name     String
  category String  // 'Clothing', 'Documents', 'Electronics'
  isPacked Boolean @default(false)
}

model Note {
  id        String   @id @default(uuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stopId    String?
  stop      Stop?    @relation(fields: [stopId], references: [id], onDelete: SetNull)
  content   String
  timestamp DateTime @default(now())
}

model SavedDestination {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cityName String
  country  String
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, success, warning, alert
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ManifestGoal {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String   // e.g., "Europe 2027"
  targetAmount Float
  savedAmount  Float    @default(0)
  currency     String   @default("INR")
  isCompleted  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
